{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/wish/srija/1.html" },
    { "source": "/index.html", "destination": "/wish/srija/1.html" },
    { "source": "/2.HTML", "destination": "/wish/srija/2.html" },
    { "source": "/:path*", "destination": "/wish/srija/:path*" }
  ]
}
